{
  "name": "academic-planner-support-hub-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "build": "npm run build -w packages/core && npm run build -w packages/db && npm run build -w apps/api && npm run build:web",
    "build:web": "npm run build -w apps/web",
    "test": "npm test -w packages/core",
    "test:unit": "npm test -w packages/core",
    "test:e2e": "node scripts/run-e2e.js",
    "test:api": "node scripts/run-api-smoke.js",
    "test:smoke": "npm run test:unit && npm run test:api",
    "test:all": "npm run test:unit && npm run test:api && npm run test:e2e",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs,.mjs",
    "format": "prettier --write .",
    "db:migrate": "npm run build -w packages/core && npm run build -w packages/db && node packages/db/dist/migrate.js",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vitest": "^1.5.0"
  }
}
